# Copy to .env (gitignored) and tweak per machine.

# --- PostgreSQL ---
POSTGRES_USER=app
POSTGRES_PASSWORD=dev
POSTGRES_DB=gcp
DB_URL=postgres://app:dev@postgres:5432/gcp?sslmode=disable

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- JWT (V4-S1) ---
# Generate a real one with: openssl rand -hex 32
JWT_SECRET=dev-only-change-me

# --- Ports (host:container) ---
API_PORT=8080
GATEWAY_PORT=8081
