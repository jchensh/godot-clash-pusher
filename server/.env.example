# Copy to .env (gitignored) and tweak per machine.
# 本地开发：不建 .env 也能跑（全部有 dev 默认值）。
# 公网部署（KAN-110 E2-lite）：下面标 ⚠️公网必改 的项全部要填真值，
#   真值只存在部署机器的 .env 里、永不进仓库；完整流程见 docs/deployment/GCP_RELEASE_TLS.md。

# --- PostgreSQL ---
POSTGRES_USER=app
# ⚠️公网必改：强随机密码，生成：openssl rand -base64 24
POSTGRES_PASSWORD=dev
POSTGRES_DB=gcp
# ⚠️公网必改：密码要与上面一致（app:密码@postgres）
DB_URL=postgres://app:dev@postgres:5432/gcp?sslmode=disable

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- JWT (V4-S1) ---
# ⚠️公网必改：泄露 = 任何人可伪造任意账号的登录态。生成：openssl rand -hex 32
JWT_SECRET=dev-only-change-me

# --- Ports (host:container) ---
API_PORT=8080
GATEWAY_PORT=8081

# --- TLS 反代（仅配合 docker-compose.prod.yml overlay 时生效，KAN-110）---
# ⚠️公网必改：指向本机公网 IP 的域名（先把 A 记录解析好；填 localhost = 本地自签冒烟模式）
DOMAIN=localhost
# 证书到期/异常通知邮箱（Let's Encrypt 要求）
ACME_EMAIL=admin@example.com
# Caddy 宿主机端口（公网保持 80/443；本地冒烟改 8088/8443 避开占用）
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
