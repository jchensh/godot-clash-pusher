# 生产环境服务配置环境变量
# 部署时，请拷贝此文件并命名为 .env，并修改下列真实值

# 1. 数据库与 Redis 配置
POSTGRES_USER=gcp_prod_user
POSTGRES_PASSWORD=your_super_secure_postgres_password
POSTGRES_DB=gcp_prod

# Docker 内部通信连接串（外部不可访问，通过主机名解析）
DB_URL=postgres://gcp_prod_user:your_super_secure_postgres_password@postgres:5432/gcp_prod?sslmode=disable
REDIS_URL=redis://redis:6379/0

# 2. 安全与接口配置
JWT_SECRET=your_production_jwt_secret_key_change_me
GM_ENABLED=0   # 生产环境必须关闭 GM 作弊后台 (0: 禁用, 1: 启用)

# 3. 部署端口配置（由 Nginx 容器接管 80/443，内网端口可保留默认）
GATEWAY_PORT=8081
API_PORT=8080
