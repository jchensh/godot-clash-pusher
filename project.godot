; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="对推小游戏"
config/description="竖屏皇室战争式对推小游戏 (V1 白膜)"
run/main_scene="res://view/main_menu.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
run/max_fps=60
config/icon="res://icon.svg"

[autoload]

_mcp_game_helper="*res://addons/godot_ai/runtime/game_helper.gd"
I18n="*res://view/i18n.gd"
AudioManager="*res://view/audio_manager.gd"
UI="*res://view/ui/ui_layers.gd"
Router="*res://view/scene_router.gd"
Events="*res://view/events.gd"
Online="*res://net/online_runtime.gd"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/stretch/mode="canvas_items"
window/handheld/orientation="portrait"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_ai/plugin.cfg")

[gui]

theme/custom_font="res://assets/fonts/fusion-pixel-12px-proportional-zh_hans.ttf"

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
